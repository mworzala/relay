<?xml version="1.0" encoding="UTF-8"?>
<!--
  RelayInputMethod Info.plist — DEBUG / dev variant (bundle id
  com.mattworzala.inputmethod.RelayInputMethod.dev).

  Sibling of Info-Release.plist; keep the two in sync EXCEPT for the four bundle-id
  occurrences below (connection name, the mode-id key, TISInputSourceID, and the
  visible-mode array), which carry the ".dev" suffix here so the dev input source is
  distinct from the installed one. Two files exist because the input-mode id is a
  plist dictionary *key* and Xcode only expands build settings in values, not keys.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>$(RELAY_DISPLAY_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Variant suffix (".dev"/"") so the helper process derives the same suffixed
	     CFMessagePort names the app uses — see IMKMessaging. -->
	<key>RelayVariantSuffix</key>
	<string>$(RELAY_VARIANT_SUFFIX)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHighResolutionCapable</key>
	<true/>

	<!-- Background-only: no Dock icon, no main menu. An input method is an agent
	     process TSM launches on demand (and that Relay also launches itself). -->
	<key>LSUIElement</key>
	<true/>

	<!-- ===== Input Method Kit keys ===== -->

	<!-- The Mach connection IMKServer registers. By convention
	     <bundleid>_Connection; main.swift reads this key back to create the server,
	     and IMKMessaging.connectionName must match it. -->
	<key>InputMethodConnectionName</key>
	<string>com.mattworzala.inputmethod.RelayInputMethod.dev_Connection</string>

	<!-- The IMKInputController subclass TSM instantiates per input session. The
	     bare class name works because the subclass is @objc(RelayInputMethodController). -->
	<key>InputMethodServerControllerClass</key>
	<string>RelayInputMethodController</string>

	<!-- One input mode. tsInputModeListKey maps a mode id (the dict key) → its
	     descriptor; that same mode id MUST be listed in
	     tsVisibleInputModeOrderedArrayKey (NOT tsVisibleInputModeOrderArray) or TIS
	     surfaces zero modes and silently drops the whole source. -->
	<key>ComponentInputModeDict</key>
	<dict>
		<key>tsInputModeListKey</key>
		<dict>
			<key>com.mattworzala.inputmethod.RelayInputMethod.dev</key>
			<dict>
				<key>TISInputSourceID</key>
				<string>com.mattworzala.inputmethod.RelayInputMethod.dev</string>
				<key>TISIntendedLanguage</key>
				<string>en</string>
				<key>tsInputModeAlternateMenuTitleStringKey</key>
				<string>Relay</string>
				<key>tsInputModeCharacterRepertoireKey</key>
				<array>
					<string>Latn</string>
				</array>
				<key>tsInputModeIsVisibleKey</key>
				<true/>
				<key>tsInputModeKeyEquivalentKey</key>
				<string></string>
				<key>tsInputModeKeyEquivalentModifiersKey</key>
				<integer>0</integer>
				<key>tsInputModePrimaryInScriptKey</key>
				<true/>
				<key>tsInputModeScriptKey</key>
				<string>smUnicodeScript</string>
			</dict>
		</dict>
		<key>tsVisibleInputModeOrderedArrayKey</key>
		<array>
			<string>com.mattworzala.inputmethod.RelayInputMethod.dev</string>
		</array>
	</dict>
</dict>
</plist>
