<?xml version="1.0" encoding="UTF-8"?>
<!--
  Relay Info.plist
  - Normal Dock app: LSUIElement is intentionally NOT set. To run as a no-Dock
    background ("accessory") app, do NOT add LSUIElement here — flip the single
    line in App/ActivationPolicy.swift instead, so the choice stays in one place.
  - NSMicrophoneUsageDescription is required for AVCaptureDevice mic access (TCC).
  - Most bundle values are injected from the XcodeGen build settings (project.yml).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>$(RELAY_DISPLAY_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Per-variant state directory under Application Support (read by AppPaths) so
	     a dev build and an installed build don't share settings/history. -->
	<key>RelayStateDirName</key>
	<string>$(RELAY_STATE_DIR_NAME)</string>
	<!-- Variant suffix (".dev"/"") the app uses to derive the IMK helper bundle id +
	     CFMessagePort names (see IMKMessaging), matching the helper it ships. -->
	<key>RelayVariantSuffix</key>
	<string>$(RELAY_VARIANT_SUFFIX)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 Relay.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Relay listens to your microphone to transcribe speech into text while you hold your dictation key.</string>
</dict>
</plist>
